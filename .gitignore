# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual Environment
venv/
ENV/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Environment variables
.env
.claude/settings.local.json

# Runtime data
runtime/cache/
runtime/logs/
*.cache
*.log

# Generated outputs - Final artifacts (some may be committed as examples)
outputs/slides/*.html
outputs/slides/*.pdf
outputs/slides/*.pptx

# Intermediate artifacts (always ignored)
outputs/intermediates/images/*.png
outputs/intermediates/images/citations/*.png
outputs/intermediates/markdown/*.md
outputs/intermediates/scripts/*.md
outputs/intermediates/plans/*.json
outputs/intermediates/citations/*.json
outputs/intermediates/temp/*

# Legacy structure (for backward compatibility)
outputs/images/*.png
outputs/markdown/*.md
outputs/charts/*.png
outputs/plans/*.md
outputs/scripts/*.md

# Temporary outputs (test/debug/backup)
outputs/test_*/
outputs/debug_*/
outputs/*_old_*/
outputs/*_backup_*/
outputs/validation_*.md
outputs/debug_bbox/
outputs/debug_detailed/
outputs/debug_figures/
outputs/test_all_figures/
outputs/test_detailed/
outputs/test_fix*/
outputs/test_max_*/
outputs/test_pymupdf/
outputs/images_old_*/

# Keep empty canonical directories
!runtime/cache/.gitkeep
!runtime/logs/.gitkeep
!outputs/slides/.gitkeep
!outputs/intermediates/images/.gitkeep
!outputs/intermediates/markdown/.gitkeep
!outputs/intermediates/scripts/.gitkeep
!outputs/intermediates/plans/.gitkeep
!outputs/intermediates/citations/.gitkeep

# OS
.DS_Store
Thumbs.db

# Testing
.pytest_cache/
.coverage
htmlcov/

# Temporary files
*.tmp
*.bak
